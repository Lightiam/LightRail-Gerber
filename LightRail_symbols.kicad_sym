
(kicad_symbol_lib (version 20211014)

 (symbol "LT8614"
  (pin power_in line (at 0 0 0) (length 100) (name VIN) (number 1))
  (pin power_out line (at 500 0 180) (length 100) (name VOUT) (number 2))
  (pin power_in line (at 250 -200 90) (length 100) (name GND) (number 3))
 )

 (symbol "TPS7A4700"
  (pin power_in line (at 0 0 0) (length 100) (name VIN) (number 1))
  (pin power_out line (at 500 0 180) (length 100) (name VOUT) (number 2))
  (pin power_in line (at 250 -200 90) (length 100) (name GND) (number 3))
 )

 (symbol "HMC8410_RF_DRIVER"
  (pin input line (at 0 0 0) (length 100) (name RF_IN) (number 1))
  (pin output line (at 500 0 180) (length 100) (name RF_OUT) (number 2))
 )

